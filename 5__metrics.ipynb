            "text/plain": [
              "<lazyfca.lazyfca.LazyFCA at 0x1f2e9c7fca0>"
            ]
          },
          "execution_count": 3,
          "metadata": {},
          "output_type": "execute_result"
        }
      ],
      "source": [
        "classifier = LazyFCA(\n",
        "    pos_params=LazyFCA.Params(\n",
        "        supporters_covered=5,\n",
        "        supporter_opposer_ratio=1 / 2.75,\n",
        "    ),\n",
        "    neg_params=LazyFCA.Params(\n",
        "        supporters_covered=10,\n",
        "        supporter_opposer_ratio=4,\n",
        "    ),\n",
        "    pos_weight=1.0\n",
        ")\n",
        "classifier.fit(X_train, y_train)"
      ]
    },
